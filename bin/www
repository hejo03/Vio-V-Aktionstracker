#!/usr/bin/env node
const app = require('../app');
const http = require('http');
const db = require('../models');
const { sendLog } = require('../helpers/utility');
require('dotenv').config();

const port = normalizePort(process.env.PORT || '3000');
app.set('port', port);

const server = http.createServer(app);

const gracefulShutdown = (signal) => {
   console.log(`\n${signal} received: closing server...`);

   server.close(async (err) => {
      if (err) {
         console.error('Server close error:', err);
         process.exit(1);
      }

      try {
         await db.sequelize.close();
         console.log('DB connection closed.');
         process.exit(0);
      } catch (dbErr) {
         console.error('DB close error:', dbErr);
         process.exit(1);
      }
   });

   setTimeout(() => {
      console.error('Force shutdown after timeout');
      process.exit(1);
   }, 10000);
};

process.on('unhandledRejection', (reason, promise) => {
   console.error('=== UNHANDLED REJECTION ===');
   console.error('Promise:', promise);
   console.error('Reason:', reason);
   sendLog(reason, 2);
});

process.on('uncaughtException', (error) => {
   console.error('=== UNCAUGHT EXCEPTION ===');
   console.error(error);
   sendLog(error, 2);
   process.exit(1);
});

process.on('SIGTERM', () => gracefulShutdown('SIGTERM'));
process.on('SIGINT', () => gracefulShutdown('SIGINT'));

db.sequelize
   .sync({ alter: true, force: false })
   .then(async () => {
      server.listen(port, () => {
         const addr = server.address();
         const bind = typeof addr === 'string' ? `pipe ${addr}` : `port ${addr.port}`;
         console.log(`✅ Server listening on ${bind}`);
         console.log(`   PID: ${process.pid}`);

         try {
            require('../helpers/crons');
            console.log('✅ Cron jobs loaded');
         } catch (cronErr) {
            console.error('❌ Cron jobs failed:', cronErr);
         }
      });

      server.on('error', onError);
   })
   .catch((syncErr) => {
      console.error('❌ DB sync failed:', syncErr);
      process.exit(1);
   });

function normalizePort(val) {
   const port = parseInt(val, 10);
   if (isNaN(port)) return val;
   if (port >= 0) return port;
   return false;
}

function onError(error) {
   if (error.syscall !== 'listen') {
      console.error('Server error:', error);
      throw error;
   }

   const bind = typeof port === 'string' ? `Pipe ${port}` : `Port ${port}`;

   console.error(`${bind}: ${error.code}`);
   sendLog(error, 2);

   switch (error.code) {
      case 'EACCES':
         console.error(`${bind} requires elevated privileges`);
         process.exit(1);
         break;
      case 'EADDRINUSE':
         console.error(`${bind} is already in use`);
         process.exit(1);
         break;
      default:
         throw error;
   }
}
