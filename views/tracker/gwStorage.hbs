{{#> layouts/base }} {{#*inline "content-block"}}
<div class="container">
    <div class="card col-12">
        <div class="card-header">Lagerplatz</div>
        <div class="card-body">
            {{#if eq (timeUntilFull -1)}} Ihr habt keine Gebiete. {{else}} Es dauert noch {{ timeUntilFull }} Stunden, bis das Lager voll ist! Derzeit kommen Stündlich {{totalWeight}} Items ins Lager.
            {{/if}}
        </div>
    </div>
</div>
{{/inline}} {{/layouts/base}}
